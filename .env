# Committed defaults — NO secrets here. Real secrets go in .env.local
# (which is gitignored). Nx auto-loads this file for `nx run`/`serve`/`build`.

# Angular's compiler doesn't support TypeScript Project References, but our
# workspace was created with --preset=ts (project references). The Nx team
# offers this opt-in escape hatch: Angular apps/libs use their own non-reference
# tsconfigs while the rest of the monorepo (NestJS, shared packages) keeps the
# project-reference setup. See docs/architecture.md for the full rationale.
NX_IGNORE_UNSUPPORTED_TS_SETUP=true
